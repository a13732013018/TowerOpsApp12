<?xml version="1.0" encoding="utf-8"?>
<!-- 登录页：顶级品牌感，精准尺寸，立体层次 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════ 品牌区：260dp · 三段靛蓝渐变 ══════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="264dp"
            android:background="@drawable/bg_login_gradient">

            <!-- 右上角装饰光晕 -->
            <View
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-40dp"
                android:layout_marginEnd="-40dp"
                android:background="@drawable/bg_glow_purple"/>

            <!-- 左下角装饰光晕 -->
            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="-30dp"
                android:layout_marginBottom="-20dp"
                android:background="@drawable/bg_glow_blue"/>

            <!-- 品牌中心内容 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingBottom="24dp">

                <!-- Logo 卡片：精准 80×80，圆角 20dp，阴影 20dp -->
                <androidx.cardview.widget.CardView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="20dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_logo_tower"
                        android:padding="14dp"
                        android:scaleType="fitCenter"/>
                </androidx.cardview.widget.CardView>

                <!-- 主标题：28sp 粗体，白色，间距适度 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="铁塔运维助手"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.04"
                    android:layout_marginTop="20dp"/>

                <!-- 副标题：英文，14sp，浅靛紫 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOWER OPERATIONS ASSISTANT"
                    android:textSize="10sp"
                    android:textColor="#B0C4FF"
                    android:letterSpacing="0.14"
                    android:layout_marginTop="6dp"/>

                <!-- 版本 chip：精致小胶囊 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:gravity="center"
                    android:background="@drawable/bg_version_badge"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="v 7.0"
                        android:textSize="10sp"
                        android:textColor="#A5B4FC"
                        android:letterSpacing="0.06"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- ══════════════ 登录表单：精准卡片布局 ══════════════ -->
        <!-- 卡片上移 -16dp 叠于品牌区，圆角 20dp 顶边，阴影 12dp -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="-20dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="@color/bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="28dp">

                <!-- 卡片标题区 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="账号登录"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:includeFontPadding="false"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="请选择账号并完成身份验证"
                    android:textSize="13sp"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"/>

                <!-- ─── 登录模式切换 Tab ─── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_input_white"
                    android:layout_marginBottom="24dp"
                    android:padding="4dp">

                    <!-- Tab: 图形码直接登录 -->
                    <TextView
                        android:id="@+id/tabDirect"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="直接登录"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_button_primary_gradient"/>

                    <!-- Tab: PIN码登录（原有模式） -->
                    <TextView
                        android:id="@+id/tabPin"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="PIN码登录"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:background="@android:color/transparent"/>
                </LinearLayout>

                <!-- ─── 账号选择 ─── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="登录账号"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp"/>

                <Spinner
                    android:id="@+id/spinnerAccount"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_white"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="20dp"/>

                <!-- ─── 图形验证码 ─── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="图形验证码"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical">

                    <!-- 验证码图 -->
                    <FrameLayout
                        android:id="@+id/flCaptcha"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_white"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/ivCaptcha"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:padding="6dp"/>
                    </FrameLayout>

                    <!-- 刷新按钮：96dp，与输入框等高 -->
                    <Button
                        android:id="@+id/btnRefreshCaptcha"
                        android:layout_width="96dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_button_secondary"
                        android:text="刷新"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_inverse"
                        android:stateListAnimator="@null"
                        android:letterSpacing="0.02"
                        android:elevation="2dp"/>
                </LinearLayout>

                <!-- 验证码输入 -->
                <EditText
                    android:id="@+id/etVerifyCode"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_white"
                    android:hint="请输入图形验证码"
                    android:textColorHint="@color/text_placeholder"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="text"
                    android:layout_marginBottom="20dp"/>

                <!-- ─── 短信/PIN码区域（PIN码登录模式专用，直接登录模式隐藏）─── -->
                <LinearLayout
                    android:id="@+id/layoutPinMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                <!-- ─── 短信验证码 ─── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="短信验证码 / PIN 码"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etPin"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_white"
                        android:hint="PIN 码"
                        android:textColorHint="@color/text_placeholder"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:inputType="text"/>

                    <!-- 获取验证码：112dp 固定宽，等高 48dp -->
                    <Button
                        android:id="@+id/btnGetSms"
                        android:layout_width="112dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_button_primary_gradient"
                        android:text="获取验证码"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_inverse"
                        android:stateListAnimator="@null"
                        android:letterSpacing="0.02"
                        android:elevation="2dp"/>
                </LinearLayout>

                </LinearLayout>

                <!-- 分割线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"/>

                <!-- 登录按钮：56dp 高，字号16，字间距 -->
                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_button_primary_gradient"
                    android:text="登  录"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_inverse"
                    android:letterSpacing="0.12"
                    android:stateListAnimator="@null"
                    android:elevation="4dp"/>

                <!-- 模式说明（动态更新） -->
                <TextView
                    android:id="@+id/tvModeHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="当前：图形验证码直接登录（无需手机短信）"
                    android:textSize="11sp"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center"/>

                <!-- 状态提示 -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="@color/error"
                    android:gravity="center"
                    android:minHeight="18dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 底部版本 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="TowerOps v7.0  ·  铁塔运维平台"
            android:textSize="11sp"
            android:textColor="@color/text_tertiary"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
