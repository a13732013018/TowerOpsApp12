<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- 顶部状态栏 · 靛蓝渐变 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@drawable/bg_header_gradient"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_logo_tower"
                android:tint="#FFFFFF"
                android:layout_marginEnd="8dp"
                android:scaleType="fitCenter"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="OMMS 授权登录"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- 操作提示 -->
        <TextView
            android:id="@+id/tvOmmsHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="① 登录4A账号  ② 点击「综合运维管理系统」菜单  ③ 自动获取凭据"
            android:textColor="#C7D2FE"
            android:textSize="11sp"
            android:maxLines="3"/>

    </LinearLayout>

    <!-- 进度条 -->
    <ProgressBar
        android:id="@+id/progressOmms"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:progressTint="@color/colorPrimary"
        android:visibility="gone"/>

    <!-- WebView 主体：撑满剩余空间 -->
    <WebView
        android:id="@+id/webViewOmms"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
