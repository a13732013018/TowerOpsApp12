<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- 顶部状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@drawable/bg_header_gradient"
        android:elevation="4dp">

        <!-- 标题行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_logo_tower"
                android:tint="#FFFFFF"
                android:layout_marginEnd="8dp"
                android:scaleType="fitCenter"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="获取巡检打卡 Token"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <!-- 重新加载按钮 -->
            <TextView
                android:id="@+id/btnTomsReload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="重新加载"
                android:textColor="#C7D2FE"
                android:textSize="11sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@null"/>

        </LinearLayout>

        <!-- 状态提示（动态更新） -->
        <TextView
            android:id="@+id/tvTomsHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="正在加载 OMMS..."
            android:textColor="#C7D2FE"
            android:textSize="11sp"
            android:lineSpacingMultiplier="1.3"
            android:maxLines="5"/>

    </LinearLayout>

    <!-- 操作步骤提示横幅 -->
    <LinearLayout
        android:id="@+id/layoutTomsGuide"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#FFF8E1">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 操作步骤（点击后自动抓取 Token）"
            android:textColor="#E65100"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="① 点击左上角 ☰ 展开菜单\n② 工单管理 → 新安全打卡\n③ 新安全打卡 → 安全打卡综合查询"
            android:textColor="#5D4037"
            android:textSize="11sp"
            android:lineSpacingMultiplier="1.4"/>

    </LinearLayout>

    <!-- 进度条 -->
    <ProgressBar
        android:id="@+id/progressToms"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:progressTint="@color/colorPrimary"
        android:visibility="gone"/>

    <!-- WebView 主体 -->
    <WebView
        android:id="@+id/webViewToms"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
