<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <!-- 顶部提示栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#16213e">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="获取4A门禁Token"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTymjHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="请点击左侧菜单「统一门禁管理端」"
            android:textColor="#b0b0b0"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 进度条 -->
    <ProgressBar
        android:id="@+id/progressTymj"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:indeterminate="true"
        android:visibility="visible" />

    <!-- 重新加载按钮 + 手动输入按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="4dp">

        <Button
            android:id="@+id/btnTymjManual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="手动输入Token"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnTymjReload"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="重新加载"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 手动输入区（默认隐藏，JS抓不到时显示） -->
    <LinearLayout
        android:id="@+id/layoutManualInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:background="#2a1a0a"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ 自动捕获失败，请手动粘贴Token"
            android:textColor="#ff9800"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etManualToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="在此粘贴 Bearer Token..."
            android:textColorHint="#888"
            android:textColor="#ffffff"
            android:textSize="13sp"
            android:inputType="textNoSuggestions"
            android:background="#3a2a1a"
            android:padding="10dp"
            android:singleLine="true" />

        <Button
            android:id="@+id/btnManualSubmit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="确认并保存"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- WebView容器 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/webViewTymj"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

</LinearLayout>
