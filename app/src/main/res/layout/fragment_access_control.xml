<?xml version="1.0" encoding="utf-8"?>
<!--
  门禁系统 Fragment v5.0
  控制面板 + 列表 + 日志（120dp）
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_base">

    <!-- ═══ 4A 登录面板 ═══ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardLogin4A"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/bg_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- 标题行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="4A 账号登录"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/tvLoginStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:text="未登录"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:background="@color/bg_panel"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- 账号选择行：36dp 高 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="账号"
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp"
                    android:includeFontPadding="false"/>

                <Spinner
                    android:id="@+id/spinnerAccount4A"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_white"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"/>

                <Button
                    android:id="@+id/btnGetSmsAc"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:text="获取验证码"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_inverse"
                    android:background="@drawable/bg_button_primary_gradient"
                    android:stateListAnimator="@null"
                    android:letterSpacing="0"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>
            </LinearLayout>

            <!-- 短信验证码行（初始隐藏）-->
            <LinearLayout
                android:id="@+id/layout4aCodeRowAc"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="短信码"
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp"
                    android:includeFontPadding="false"/>

                <EditText
                    android:id="@+id/etPinAc"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_white"
                    android:hint="输入短信验证码"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_placeholder"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:inputType="number"
                    android:singleLine="true"/>

                <Button
                    android:id="@+id/btnLoginAc"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:text="确认登录"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_inverse"
                    android:background="@drawable/bg_button_primary_gradient"
                    android:stateListAnimator="@null"
                    android:letterSpacing="0"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══ 已登录状态行 ═══ -->
    <LinearLayout
        android:id="@+id/layoutLoggedIn4A"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone"
        android:background="@color/success_light">

        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/success"/>

        <TextView
            android:id="@+id/tvLoggedInUser"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✅  已登录: wx-linjy22"
            android:textColor="@color/success_text"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginStart="10dp"
            android:includeFontPadding="false"/>

        <Button
            android:id="@+id/btnLogout4A"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="退出登录"
            android:textSize="10sp"
            android:textColor="@color/error"
            android:background="@drawable/bg_button_outline_error"
            android:stateListAnimator="@null"
            android:letterSpacing="0"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>
    </LinearLayout>

    <!-- ═══ 门禁配置面板 ═══ -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="4dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/bg_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- 标题 + 自动开门开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="门禁系统监控"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false"/>

                <CheckBox
                    android:id="@+id/cbAcAutoOpen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="自动开门"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:buttonTint="@color/colorPrimary"
                    android:checked="true"
                    android:minHeight="0dp"/>
            </LinearLayout>

            <!-- 启动/停止按钮行：36dp 统一 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <Button
                    android:id="@+id/btnAcStart"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="开启蓝牙进站监控"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_inverse"
                    android:background="@drawable/bg_button_primary_gradient"
                    android:stateListAnimator="@null"
                    android:letterSpacing="0"/>

                <Button
                    android:id="@+id/btnAcStop"
                    android:layout_width="72dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:text="停止"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_inverse"
                    android:background="@drawable/bg_button_secondary"
                    android:stateListAnimator="@null"
                    android:letterSpacing="0"
                    android:enabled="false"/>
            </LinearLayout>

            <!-- OMMS Cookie 行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OMMS"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:layout_marginEnd="8dp"
                    android:includeFontPadding="false"/>

                <EditText
                    android:id="@+id/etOmmsCookie"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="点右侧登录，或开启监控自动获取"
                    android:textSize="9.5sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_placeholder"
                    android:background="@drawable/bg_input_white"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:inputType="textMultiLine"
                    android:minLines="1"
                    android:maxLines="2"/>

                <Button
                    android:id="@+id/btnOmmsLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:text="OMMS登录"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_inverse"
                    android:backgroundTint="@color/colorPrimary"
                    android:stateListAnimator="@null"
                    android:letterSpacing="0"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"/>
            </LinearLayout>

            <!-- 4A Token 行（用于门禁数据Tab查询4A开门记录） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4A-T"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:layout_marginEnd="8dp"
                    android:includeFontPadding="false"/>

                <EditText
                    android:id="@+id/et4AToken"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="粘贴4A系统Bearer Token（门禁数据Tab使用）"
                    android:textSize="9.5sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_placeholder"
                    android:background="@drawable/bg_input_white"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:inputType="textMultiLine"
                    android:minLines="1"
                    android:maxLines="2"/>

                <EditText
                    android:id="@+id/et4ACountyCode"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:hint="县级代码"
                    android:textSize="9.5sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_placeholder"
                    android:background="@drawable/bg_input_white"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:inputType="text"/>

                <Button
                    android:id="@+id/btn4ASave"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="6dp"
                    android:text="保存"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_inverse"
                    android:backgroundTint="#7C3AED"
                    android:stateListAnimator="@null"
                    android:letterSpacing="0"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"/>

                <Button
                    android:id="@+id/btn4AGet"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="6dp"
                    android:text="从4A获取"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_inverse"
                    android:backgroundTint="#059669"
                    android:stateListAnimator="@null"
                    android:letterSpacing="0"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"/>
            </LinearLayout>

            <!-- 说明文字 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bearer Token：查询4A门禁开门记录的认证令牌。点「从4A获取」自动完成（需先登录4A账号）。"
                android:textColor="@color/text_tertiary"
                android:textSize="9.5sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══ 日志面板：120dp ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:orientation="vertical"
        android:background="@color/log_background">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/log_border"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@color/log_header_bg"
            android:gravity="center_vertical">

            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_dot_circle_red" android:layout_marginEnd="5dp"/>
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_dot_circle_yellow" android:layout_marginEnd="5dp"/>
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_dot_circle_green" android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="运行日志"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/log_title"
                android:fontFamily="monospace"
                android:includeFontPadding="false"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:text="● LIVE"
                android:textSize="8sp"
                android:textColor="@color/success"
                android:textStyle="bold"
                android:background="@color/success_light"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:gravity="center"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/log_border"/>

        <ScrollView
            android:id="@+id/scrollAcLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp">

            <TextView
                android:id="@+id/tvAcLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="9.5sp"
                android:textColor="@color/log_text"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5"
                android:includeFontPadding="false"
                android:text="等待启动..."/>
        </ScrollView>
    </LinearLayout>

    <!-- ═══ 表头：精准 28dp ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:background="@color/bg_panel"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="18dp"
            android:layout_height="wrap_content"
            android:text="#"
            android:textColor="@color/text_tertiary"
            android:textSize="9sp"
            android:gravity="center"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:text="站名"
            android:textColor="@color/text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginStart="2dp"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="告警时间"
            android:textColor="@color/text_secondary"
            android:textSize="8sp"
            android:gravity="center"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="蓝牙出站"
            android:textColor="@color/text_secondary"
            android:textSize="8sp"
            android:gravity="center"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="26dp"
            android:layout_height="wrap_content"
            android:text="蓝∆"
            android:textColor="@color/text_secondary"
            android:textSize="8sp"
            android:gravity="center"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:text="状态"
            android:textColor="@color/text_secondary"
            android:textSize="8sp"
            android:textStyle="bold"
            android:gravity="center"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="远程开门"
            android:textColor="@color/text_secondary"
            android:textSize="8sp"
            android:gravity="center"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="26dp"
            android:layout_height="wrap_content"
            android:text="远∆"
            android:textColor="@color/text_secondary"
            android:textSize="8sp"
            android:gravity="center"
            android:includeFontPadding="false"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_strong"/>

    <!-- ═══ 门禁列表 ═══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAccessControl"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg_base"/>

</LinearLayout>
