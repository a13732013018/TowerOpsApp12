<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- 顶部控制栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <!-- 自动审批开关行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自动审批"
                android:textSize="13sp"
                android:textColor="#1F2937"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchAutoApproval"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:checked="false" />

            <TextView
                android:id="@+id/tvAutoStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textSize="10sp"
                android:textColor="#64748B"
                android:text="已关闭" />

            <TextView
                android:id="@+id/tvApprovalCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#374151"
                android:text="待审批 0 条" />
        </LinearLayout>

        <!-- 操作行（手动模式） -->
        <LinearLayout
            android:id="@+id/layoutManualButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="6dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnApprovalRefresh"
                android:layout_width="64dp"
                android:layout_height="30dp"
                android:text="刷新"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4F46E5"
                android:stateListAnimator="@null"
                android:letterSpacing="0"
                android:layout_gravity="center_vertical" />

            <Button
                android:id="@+id/btnApprovalAll"
                android:layout_width="88dp"
                android:layout_height="30dp"
                android:layout_marginStart="4dp"
                android:text="一键审批"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#DC2626"
                android:stateListAnimator="@null"
                android:letterSpacing="0"
                android:gravity="center"
                android:layout_gravity="center_vertical" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textSize="10sp"
                android:textColor="#94A3B8"
                android:text="手动模式" />
        </LinearLayout>

        <!-- 状态行 -->
        <TextView
            android:id="@+id/tvApprovalStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="8dp"
            android:textSize="11sp"
            android:textColor="#64748B"
            android:text="点击「刷新」获取待审批工单，或开启自动审批" />
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0" />

    <!-- 列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDoorApproval"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- 空状态提示 -->
    <TextView
        android:id="@+id/tvApprovalEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="#94A3B8"
        android:text="暂无待审批工单"
        android:visibility="gone" />

</LinearLayout>
