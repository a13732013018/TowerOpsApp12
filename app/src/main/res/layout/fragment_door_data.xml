<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- 顶栏：日期范围 + 查询 + 导出 + 状态 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <!-- 日期范围行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="2dp"
            android:gravity="center_vertical">

            <Spinner
                android:id="@+id/spnDoorRegion"
                android:layout_width="68dp"
                android:layout_height="32dp"
                android:background="@android:drawable/spinner_background"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="告警时间："
                android:textSize="11sp"
                android:textColor="#374151" />

            <TextView
                android:id="@+id/tvDoorStartDate"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#1E293B"
                android:background="#F1F5F9"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="16dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="—"
                android:textSize="11sp"
                android:textColor="#94A3B8" />

            <TextView
                android:id="@+id/tvDoorEndDate"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#1E293B"
                android:background="#F1F5F9"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- 查询/导出/状态行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnDoorDataQuery"
                android:layout_width="72dp"
                android:layout_height="36dp"
                android:text="查询"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4F46E5"
                android:stateListAnimator="@null"
                android:letterSpacing="0"
                android:layout_gravity="center_vertical" />

            <Button
                android:id="@+id/btnDoorDataExport"
                android:layout_width="72dp"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:text="导出"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0891B2"
                android:stateListAnimator="@null"
                android:letterSpacing="0"
                android:layout_gravity="center_vertical"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDoorDataStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textSize="11sp"
                android:textColor="#555555"
                android:maxLines="2"
                android:text="就绪" />
        </LinearLayout>
    </LinearLayout>

    <!-- 汇总卡片 -->
    <LinearLayout
        android:id="@+id/layoutDoorDataSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#FFFFFF"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvDoorDataTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:text="0" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#64748B"
                android:text="总站数" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvDoorDataOk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#16A34A"
                android:text="0" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#64748B"
                android:text="合格站" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvDoorDataFail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#DC2626"
                android:text="0" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#64748B"
                android:text="不合格站" />
        </LinearLayout>
    </LinearLayout>

    <!-- 表头（可点击排序） -->
    <LinearLayout
        android:id="@+id/layoutDoorDataHeader"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="horizontal"
        android:background="#E8EAF0"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="24dp"
            android:layout_height="match_parent"
            android:text="#"
            android:textSize="9sp"
            android:textColor="#374151"
            android:textStyle="bold"
            android:gravity="center_vertical" />

        <!-- 站名（可排序） -->
        <TextView
            android:id="@+id/thDoorStName"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:text="站名"
            android:textSize="9sp"
            android:textColor="#374151"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:text="告警类型"
            android:textSize="9sp"
            android:textColor="#374151"
            android:textStyle="bold"
            android:gravity="center_vertical" />

        <!-- 告警时间（可排序） -->
        <TextView
            android:id="@+id/thDoorAlarmTime"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.3"
            android:text="告警时间"
            android:textSize="9sp"
            android:textColor="#374151"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true" />

        <!-- 蓝牙时间（可排序） -->
        <TextView
            android:id="@+id/thDoorBtTime"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.3"
            android:text="蓝牙时间"
            android:textSize="9sp"
            android:textColor="#374151"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true" />

        <!-- 时差（可排序） -->
        <TextView
            android:id="@+id/thDoorDiff"
            android:layout_width="34dp"
            android:layout_height="match_parent"
            android:text="差"
            android:textSize="9sp"
            android:textColor="#374151"
            android:textStyle="bold"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

        <!-- 结果（可排序） -->
        <TextView
            android:id="@+id/thDoorQualified"
            android:layout_width="52dp"
            android:layout_height="match_parent"
            android:text="结果"
            android:textSize="9sp"
            android:textColor="#374151"
            android:textStyle="bold"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- 列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDoorData"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="4dp" />
</LinearLayout>
