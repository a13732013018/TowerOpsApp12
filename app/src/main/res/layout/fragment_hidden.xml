<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- 查询控件区（无日期，查全部） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:elevation="2dp"
        android:gravity="center_vertical">
        <Button
            android:id="@+id/btnHiddenQuery"
            android:layout_width="80dp"
            android:layout_height="32dp"
            android:text="查询全部"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4F46E5"
            android:padding="0dp"
            android:stateListAnimator="@null"/>
        <TextView
            android:id="@+id/tvHiddenStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textSize="11sp"
            android:textColor="#6B7280"/>
    </LinearLayout>

    <!-- 统计卡片区（合计 + 等待）-->
    <LinearLayout
        android:id="@+id/layoutHiddenSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:visibility="gone">

        <!-- 总条数 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">
            <TextView
                android:id="@+id/tvHiddenTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#4F46E5"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="总条数"
                android:textSize="9sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <!-- 超7天 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginStart="3dp">
            <TextView
                android:id="@+id/tvHiddenOver7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#D97706"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">7天"
                android:textSize="9sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <!-- 超15天 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginStart="3dp">
            <TextView
                android:id="@+id/tvHiddenOver15"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#EA580C"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">15天"
                android:textSize="9sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <!-- 超30天 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginStart="3dp">
            <TextView
                android:id="@+id/tvHiddenOver30"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#DC2626"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">30天"
                android:textSize="9sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <!-- 超90天 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginStart="3dp">
            <TextView
                android:id="@+id/tvHiddenOver90"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#7C3AED"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">90天"
                android:textSize="9sp"
                android:textColor="#888888"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 统计明细（等级/状态/归类三栏） -->
    <LinearLayout
        android:id="@+id/layoutHiddenStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone">

        <!-- 隐患等级 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:padding="8dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="隐患等级"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:id="@+id/tvHiddenLevelStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#4B5563"
                android:lineSpacingExtra="2dp"/>
        </LinearLayout>

        <!-- 隐患状态 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:padding="8dp"
            android:layout_marginStart="4dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="隐患状态"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:id="@+id/tvHiddenStatusStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#4B5563"
                android:lineSpacingExtra="2dp"/>
        </LinearLayout>

        <!-- 隐患归类 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:padding="8dp"
            android:layout_marginStart="4dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="隐患归类"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:id="@+id/tvHiddenCategoryStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#4B5563"
                android:lineSpacingExtra="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 列表表头（单击可排序） -->
    <LinearLayout
        android:id="@+id/layoutHiddenHeader"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:background="#E5E7EB"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical"
        android:visibility="gone">
        <TextView
            android:id="@+id/tvHiddenSortStation"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:text="站址名称 ↕"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#374151"
            android:gravity="center_vertical"/>
        <TextView
            android:id="@+id/tvHiddenSortLevel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:text="等级 ↕"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#374151"
            android:gravity="center"/>
        <TextView
            android:id="@+id/tvHiddenSortStatus"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:text="状态 ↕"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#374151"
            android:gravity="center"/>
        <TextView
            android:id="@+id/tvHiddenSortDays"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:text="天数 ↕"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#374151"
            android:gravity="center"/>
    </LinearLayout>

    <!-- 列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHidden"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F5F7FA"/>

</LinearLayout>
