<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_base">

    <!-- ======== 排序工具栏 ======== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="排序"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="10dp"
            android:background="@color/divider_strong"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"/>

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/btnSortVoltage"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:text="电压 ↕"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_inactive"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/btnSortLoadCurrent"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:text="负载电流 ↕"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_inactive"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:layout_marginStart="6dp"/>

                <TextView
                    android:id="@+id/btnSortAlarmTime"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:text="告警时间 ↕"
                    android:textSize="10sp"
                    android:textColor="@color/text_inverse"
                    android:background="@drawable/bg_tag_primary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- ======== 表头 ======== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:orientation="horizontal"
        android:background="@color/background_tertiary"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="22dp"
            android:layout_height="wrap_content"
            android:text="#"
            android:textColor="@color/text_tertiary"
            android:textSize="9sp"
            android:gravity="center"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="站点名称"
            android:textColor="@color/text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="46dp"
            android:layout_height="wrap_content"
            android:text="电压(V)"
            android:textColor="@color/text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="end"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:text="负载(A)"
            android:textColor="@color/text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginStart="2dp"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="类型"
            android:textColor="@color/text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginStart="4dp"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="告警时间"
            android:textColor="@color/text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginStart="4dp"
            android:includeFontPadding="false"/>
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_strong"/>

    <!-- ======== 停电列表 ======== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPowerOutages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background_primary"/>

</LinearLayout>
