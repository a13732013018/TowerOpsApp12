<?xml version="1.0" encoding="utf-8"?>
<!--
  省内工单处理及时率 Fragment v1.0
  功能：省内工单处理及时率数据查询与展示
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_base">

    <!-- ═══ 控制面板卡片 ═══ -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/bg_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- 状态行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tvOrderRateStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="省内工单处理及时率"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--:--"
                    android:textSize="12sp"
                    android:textColor="@color/text_tertiary"
                    android:fontFamily="monospace"
                    android:layout_marginEnd="10dp"
                    android:includeFontPadding="false"/>

                <!-- 及时率Chip -->
                <TextView
                    android:id="@+id/tvAvgRate"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="--%"
                    android:textSize="11sp"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"
                    android:background="@color/primary_light"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="10dp"/>

            <!-- 查询控制行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="统计日期"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:includeFontPadding="false"/>

                <EditText
                    android:id="@+id/etDataDate"
                    android:layout_width="120dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="6dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:inputType="date"
                    android:hint="2026-01-01"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <!-- 查询按钮 -->
                <Button
                    android:id="@+id/btnQuery"
                    android:layout_width="72dp"
                    android:layout_height="36dp"
                    android:text="查询"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_primary_gradient"
                    android:textColor="@color/text_inverse"
                    android:stateListAnimator="@null"
                    android:minHeight="0dp"
                    android:letterSpacing="0"
                    android:padding="0dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══ 列表区 ═══ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvOrderRate"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false"/>

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="暂无数据"
            android:textSize="13sp"
            android:textColor="@color/text_tertiary"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- ═══ 日志面板 ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="vertical"
        android:background="@color/log_background">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/log_border"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@color/log_header_bg"
            android:gravity="center_vertical">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_circle_red"
                android:layout_marginEnd="5dp"/>
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_circle_yellow"
                android:layout_marginEnd="5dp"/>
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_circle_green"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="操作日志"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/log_title"
                android:fontFamily="monospace"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/log_border"/>

        <ScrollView
            android:id="@+id/svLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="9.5sp"
                android:textColor="@color/log_text"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5"
                android:includeFontPadding="false"/>
        </ScrollView>
    </LinearLayout>

</LinearLayout>
