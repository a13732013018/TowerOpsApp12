<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- 顶部控制栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- 日期行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="始:"
                android:textSize="11sp"
                android:textColor="#555555"/>

            <Button
                android:id="@+id/btnRepairStartMinus"
                android:layout_width="24dp"
                android:layout_height="32dp"
                android:text="&lt;"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="#2563EB"
                android:stateListAnimator="@null"
                android:padding="0dp"
                android:layout_marginStart="1dp"/>

            <EditText
                android:id="@+id/etRepairStartDate"
                android:layout_width="88dp"
                android:layout_height="32dp"
                android:textSize="11sp"
                android:hint="2026-03-01"
                android:singleLine="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:background="@android:drawable/edit_text"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"/>

            <Button
                android:id="@+id/btnRepairStartPlus"
                android:layout_width="24dp"
                android:layout_height="32dp"
                android:text="&gt;"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="#2563EB"
                android:stateListAnimator="@null"
                android:padding="0dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" 终:"
                android:textSize="11sp"
                android:textColor="#555555"
                android:layout_marginStart="2dp"/>

            <Button
                android:id="@+id/btnRepairEndMinus"
                android:layout_width="24dp"
                android:layout_height="32dp"
                android:text="&lt;"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="#2563EB"
                android:stateListAnimator="@null"
                android:padding="0dp"
                android:layout_marginStart="1dp"/>

            <EditText
                android:id="@+id/etRepairEndDate"
                android:layout_width="88dp"
                android:layout_height="32dp"
                android:textSize="11sp"
                android:hint="2026-03-30"
                android:singleLine="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:background="@android:drawable/edit_text"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"/>

            <Button
                android:id="@+id/btnRepairEndPlus"
                android:layout_width="24dp"
                android:layout_height="32dp"
                android:text="&gt;"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="#2563EB"
                android:stateListAnimator="@null"
                android:padding="0dp"/>

            <!-- 查询按钮 -->
            <Button
                android:id="@+id/btnRepairQuery"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:text="查 询"
                android:textSize="12sp"
                android:includeFontPadding="false"
                android:textColor="#FFFFFF"
                android:background="#2563EB"
                android:stateListAnimator="@null"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 状态文字 -->
    <TextView
        android:id="@+id/tvRepairStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="请先完成 OMMS 登录后查询"
        android:textSize="11sp"
        android:textColor="#888888"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"/>

    <!-- 汇总卡片行 -->
    <LinearLayout
        android:id="@+id/layoutRepairSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <!-- 总费用 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginEnd="3dp">
            <TextView
                android:id="@+id/tvRepairTotalCost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2563EB"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="总费用(元)"
                android:textSize="9sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <!-- 有效费用 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginEnd="3dp">
            <TextView
                android:id="@+id/tvRepairValidCost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#16A34A"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="有效(元)"
                android:textSize="9sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <!-- 无效费用 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginEnd="3dp">
            <TextView
                android:id="@+id/tvRepairInvalidCost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#DC2626"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="无效(元)"
                android:textSize="9sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <!-- 条数 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">
            <TextView
                android:id="@+id/tvRepairTotalCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#D97706"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="总条数"
                android:textSize="9sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <!-- 无效条数 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginStart="3dp">
            <TextView
                android:id="@+id/tvRepairInvalidCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#DC2626"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="无效单(条)"
                android:textSize="9sp"
                android:textColor="#888888"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 表头 -->
    <LinearLayout
        android:id="@+id/layoutRepairHeader"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:background="#E8EDF5"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:text="姓名"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#374151"
            android:gravity="center_vertical"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="总/无"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#374151"
            android:gravity="center"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:text="总费用"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#2563EB"
            android:gravity="center"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:text="有效"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#16A34A"
            android:gravity="center"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:text="无效"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#DC2626"
            android:gravity="center"/>
    </LinearLayout>

    <!-- 列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRepair"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F5F7FA"/>

    <!-- 合计行（底部固定）-->
    <LinearLayout
        android:id="@+id/layoutRepairTotal"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="#1E3A5F"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <!-- 占位（对应箭头+姓名 weight=2+16dp，近似用weight=2.2） -->
        <TextView
            android:layout_width="16dp"
            android:layout_height="wrap_content"
            android:text=""/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="合计"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <!-- 总/无条数 -->
        <TextView
            android:id="@+id/tvTotalRowCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="10sp"
            android:textColor="#FCD34D"
            android:gravity="center"/>

        <!-- 总费用 -->
        <TextView
            android:id="@+id/tvTotalRowCost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#93C5FD"
            android:gravity="center"/>

        <!-- 有效 -->
        <TextView
            android:id="@+id/tvTotalRowValid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:textSize="11sp"
            android:textColor="#6EE7B7"
            android:gravity="center"/>

        <!-- 无效 -->
        <TextView
            android:id="@+id/tvTotalRowInvalid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:textSize="11sp"
            android:textColor="#FCA5A5"
            android:gravity="center"/>
    </LinearLayout>

</LinearLayout>
