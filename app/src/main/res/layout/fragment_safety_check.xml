<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- 顶部控制栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- 日期行：← 开始日期 → | ← 结束日期 → | 查询 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 开始日期 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开始:"
                android:textSize="11sp"
                android:textColor="#555555"/>

            <Button
                android:id="@+id/btnStartMinus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="&lt;"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="#2563EB"
                android:stateListAnimator="@null"
                android:padding="0dp"
                android:layout_marginStart="2dp"/>

            <EditText
                android:id="@+id/etStartDate"
                android:layout_width="74dp"
                android:layout_height="30dp"
                android:textSize="11sp"
                android:hint="2026-03-01"
                android:singleLine="true"
                android:gravity="center"
                android:background="@android:drawable/edit_text"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"/>

            <Button
                android:id="@+id/btnStartPlus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="&gt;"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="#2563EB"
                android:stateListAnimator="@null"
                android:padding="0dp"/>

            <!-- 结束日期 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="结束:"
                android:textSize="11sp"
                android:textColor="#555555"
                android:layout_marginStart="4dp"/>

            <Button
                android:id="@+id/btnEndMinus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="&lt;"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="#2563EB"
                android:stateListAnimator="@null"
                android:padding="0dp"
                android:layout_marginStart="2dp"/>

            <EditText
                android:id="@+id/etEndDate"
                android:layout_width="74dp"
                android:layout_height="30dp"
                android:textSize="11sp"
                android:hint="2026-03-29"
                android:singleLine="true"
                android:gravity="center"
                android:background="@android:drawable/edit_text"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"/>

            <Button
                android:id="@+id/btnEndPlus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="&gt;"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="#2563EB"
                android:stateListAnimator="@null"
                android:padding="0dp"/>

            <!-- 查询按钮 -->
            <Button
                android:id="@+id/btnQuerySafetyCheck"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:minWidth="60dp"
                android:layout_marginStart="4dp"
                android:text="查询统计"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="#2563EB"
                android:stateListAnimator="@null"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"/>
        </LinearLayout>




        <!-- 第三行：巡检Token获取按钮（暂不统计巡检打卡，隐藏此行） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvTomsTokenStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="巡检Token：未获取"
                android:textSize="10sp"
                android:textColor="#888888"
                android:singleLine="true"
                android:ellipsize="end"/>

            <Button
                android:id="@+id/btnGetTomsToken"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:layout_marginStart="8dp"
                android:text="获取巡检Token"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:background="#7C3AED"
                android:stateListAnimator="@null"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 状态文字 -->
    <TextView
        android:id="@+id/tvSafetyCheckStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="请先完成 OMMS 登录后再查询打卡统计"
        android:textSize="11sp"
        android:textColor="#888888"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"/>

    <!-- 汇总卡片 -->
    <LinearLayout
        android:id="@+id/layoutSummaryCards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/cardTotal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginEnd="4dp">
            <TextView
                android:id="@+id/tvTotalCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2563EB"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="总打卡"
                android:textSize="10sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardQualified"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginEnd="4dp">
            <TextView
                android:id="@+id/tvQualifiedCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#16A34A"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="合格"
                android:textSize="10sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardUnqualified"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginEnd="4dp">
            <TextView
                android:id="@+id/tvUnqualifiedCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#DC2626"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="不合格"
                android:textSize="10sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardPersons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">
            <TextView
                android:id="@+id/tvPersonCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#D97706"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="人员"
                android:textSize="10sp"
                android:textColor="#888888"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 表头 -->
    <LinearLayout
        android:id="@+id/layoutTableHeader"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:background="#E8EDF5"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2.2"
            android:text="姓名"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#374151"
            android:gravity="center_vertical"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="天数"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#374151"
            android:gravity="center"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="次数"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#374151"
            android:gravity="center"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="合格"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#16A34A"
            android:gravity="center"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="不合格"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#DC2626"
            android:gravity="center"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.3"
            android:text="合格率"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#2563EB"
            android:gravity="center"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:text="均时长(分)"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#374151"
            android:gravity="center"/>
    </LinearLayout>

    <!-- 列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSafetyCheck"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F5F7FA"/>

</LinearLayout>
