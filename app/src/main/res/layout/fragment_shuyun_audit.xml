<?xml version="1.0" encoding="utf-8"?>
<!--
  数运审核 Fragment v5.0
  三色审核按钮 + 信息卡片 + 数据面板 + 日志
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_base">

    <!-- ═══ 审核控制面板卡片 ═══ -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/bg_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- 区县选择行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="选择区县"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:includeFontPadding="false"/>

                <Spinner
                    android:id="@+id/spinnerCounty"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:dropDownWidth="180dp"
                    android:spinnerMode="dropdown"/>
            </LinearLayout>

            <!-- 三色审核按钮：精准等比，36dp 高 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnCountyAudit"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="县级审核"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#D97706"
                    android:stateListAnimator="@null"
                    android:minHeight="0dp"
                    android:letterSpacing="0"/>

                <Button
                    android:id="@+id/btnCityAudit"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="市级审核"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#7C3AED"
                    android:stateListAnimator="@null"
                    android:minHeight="0dp"
                    android:letterSpacing="0"/>

                <Button
                    android:id="@+id/btnProvinceAudit"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="省级审核"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#0D9488"
                    android:stateListAnimator="@null"
                    android:minHeight="0dp"
                    android:letterSpacing="0"/>
            </LinearLayout>

            <!-- 三列停止按钮：28dp 高 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnStopCountyAudit"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="停止"
                    android:textSize="11sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/error"
                    android:stateListAnimator="@null"
                    android:minHeight="0dp"
                    android:letterSpacing="0"
                    android:enabled="false"/>

                <Button
                    android:id="@+id/btnStopCityAudit"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="停止"
                    android:textSize="11sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/error"
                    android:stateListAnimator="@null"
                    android:minHeight="0dp"
                    android:letterSpacing="0"
                    android:enabled="false"/>

                <Button
                    android:id="@+id/btnStopProvinceAudit"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="停止"
                    android:textSize="11sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/error"
                    android:stateListAnimator="@null"
                    android:minHeight="0dp"
                    android:letterSpacing="0"
                    android:enabled="false"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══ 运行原理说明卡片 ═══ -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="6dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp"
        app:cardBackgroundColor="@color/info_light">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="运行原理"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/info_text"
                android:layout_marginBottom="5dp"
                android:includeFontPadding="false"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="县级：循环审批，每3条延迟4-8秒，45-105秒周期检查"
                android:textSize="9.5sp"
                android:textColor="#D97706"
                android:layout_marginBottom="2dp"
                android:includeFontPadding="false"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="市级：循环审批，延期优先+普通兜底，50-100秒周期"
                android:textSize="9.5sp"
                android:textColor="#7C3AED"
                android:layout_marginBottom="2dp"
                android:includeFontPadding="false"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="省级：手动审核，需APP登录获取IMEI授权，需开发者权限"
                android:textSize="9.5sp"
                android:textColor="#0D9488"
                android:layout_marginBottom="6dp"
                android:includeFontPadding="false"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/info_border"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="步骤：① 监控页面登录PC+APP端  ② 选择区县  ③ 点击对应审核按钮  ④ 省级需手动确认"
                android:textSize="9.5sp"
                android:textColor="@color/text_tertiary"
                android:includeFontPadding="false"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══ 数据面板：两列并排 ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="6dp">

        <!-- 市级已办（左）：精准高度 -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#F5F3FF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="市级已办"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#7C3AED"
                    android:layout_marginBottom="4dp"
                    android:includeFontPadding="false"/>

                <ListView
                    android:id="@+id/lvCityTodoList"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:divider="#DDD6FE"
                    android:dividerHeight="0.5dp"
                    android:scrollbars="vertical"/>

                <TextView
                    android:id="@+id/tvCityTodoList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="暂无待办"
                    android:textSize="9.5sp"
                    android:textColor="#6D28D9"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 省监控回单（右）-->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#F0FDFA">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="省监控回单"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#0D9488"
                        android:includeFontPadding="false"/>

                    <Button
                        android:id="@+id/btnProvinceMonitorAudit"
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:text="回单"
                        android:textSize="10sp"
                        android:textColor="@android:color/white"
                        android:backgroundTint="@color/error"
                        android:stateListAnimator="@null"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:letterSpacing="0"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>
                </LinearLayout>

                <ListView
                    android:id="@+id/lvCityFinishedList"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:divider="#99F6E4"
                    android:dividerHeight="0.5dp"
                    android:scrollbars="vertical"/>

                <TextView
                    android:id="@+id/tvCityFinishedList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="暂无省监控工单"
                    android:textSize="9.5sp"
                    android:textColor="#0F766E"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- ═══ 审核日志：充满剩余空间 ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/log_background">

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/log_border"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@color/log_header_bg"
            android:gravity="center_vertical">

            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_dot_circle_red" android:layout_marginEnd="5dp"/>
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_dot_circle_yellow" android:layout_marginEnd="5dp"/>
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_dot_circle_green" android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="审核日志"
                android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/log_title" android:fontFamily="monospace"
                android:includeFontPadding="false"/>

            <TextView android:layout_width="wrap_content" android:layout_height="18dp"
                android:text="● LIVE" android:textSize="8sp"
                android:textColor="@color/success" android:textStyle="bold"
                android:background="@color/success_light"
                android:paddingStart="6dp" android:paddingEnd="6dp"
                android:gravity="center" android:includeFontPadding="false"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/log_border"/>

        <ScrollView
            android:id="@+id/svAuditLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:paddingTop="5dp" android:paddingBottom="5dp">

            <TextView
                android:id="@+id/tvAuditLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="9.5sp"
                android:textColor="@color/log_text"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5"
                android:includeFontPadding="false"/>
        </ScrollView>
    </LinearLayout>

</LinearLayout>
