<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- 顶部控制栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@color/background_secondary">

        <!-- 第一行：区域选择 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="区域:"
                android:textSize="12sp"
                android:textColor="@color/text_primary" />

            <Spinner
                android:id="@+id/spinnerArea"
                android:layout_width="100dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_spinner" />

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:textSize="11sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- 第二行：开始日期 -1 +1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开始:"
                android:textSize="11sp"
                android:textColor="@color/text_secondary" />

            <Button
                android:id="@+id/btnStartMinus"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:layout_marginStart="4dp"
                android:text="-1"
                android:textSize="11sp"
                android:backgroundTint="#64748B"
                android:stateListAnimator="@null"
                android:letterSpacing="0"
                android:padding="0dp" />

            <TextView
                android:id="@+id/tvStartDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnStartPlus"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:text="+1"
                android:textSize="11sp"
                android:backgroundTint="#64748B"
                android:stateListAnimator="@null"
                android:letterSpacing="0"
                android:padding="0dp" />
        </LinearLayout>

        <!-- 第三行：结束日期 -1 +1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="结束:"
                android:textSize="11sp"
                android:textColor="@color/text_secondary" />

            <Button
                android:id="@+id/btnEndMinus"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:layout_marginStart="4dp"
                android:text="-1"
                android:textSize="11sp"
                android:backgroundTint="#64748B"
                android:stateListAnimator="@null"
                android:letterSpacing="0"
                android:padding="0dp" />

            <TextView
                android:id="@+id/tvEndDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnEndPlus"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:text="+1"
                android:textSize="11sp"
                android:backgroundTint="#64748B"
                android:stateListAnimator="@null"
                android:letterSpacing="0"
                android:padding="0dp" />
        </LinearLayout>

        <!-- 第四行：查询按钮 + 统计 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnQuery"
                android:layout_width="64dp"
                android:layout_height="32dp"
                android:text="查询"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/colorPrimary"
                android:stateListAnimator="@null"
                android:letterSpacing="0" />

            <TextView
                android:id="@+id/tvReportStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:text="点击查询" />

            <TextView
                android:id="@+id/tvTotalCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold"
                android:text="共 0 条" />
        </LinearLayout>
    </LinearLayout>

    <!-- 调试日志区域 -->
    <TextView
        android:id="@+id/tvDebug"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:background="#1A000000"
        android:textSize="10sp"
        android:textColor="#333333"
        android:fontFamily="monospace"
        android:maxLines="4"
        android:text="" />

    <!-- 表头（可点击排序）- 水平滚动 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="@color/background_secondary"
            android:gravity="center_vertical">

            <!-- 序号 -->
            <TextView
                android:id="@+id/tvHeadIndex"
                android:layout_width="28dp"
                android:layout_height="24dp"
                android:text="#"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />

            <!-- 地市 -->
            <TextView
                android:id="@+id/tvHeadArea"
                android:layout_width="50dp"
                android:layout_height="24dp"
                android:text="地市"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />

            <!-- 区县 -->
            <TextView
                android:id="@+id/tvHeadCity"
                android:layout_width="50dp"
                android:layout_height="24dp"
                android:text="区县"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />

            <!-- 起止日期 -->
            <TextView
                android:id="@+id/tvHeadPeriod"
                android:layout_width="90dp"
                android:layout_height="24dp"
                android:text="起止日期"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />

            <!-- 中台派单 -->
            <TextView
                android:id="@+id/tvHeadEasyOrder"
                android:layout_width="60dp"
                android:layout_height="24dp"
                android:text="中台派单"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />

            <!-- 系统派单 -->
            <TextView
                android:id="@+id/tvHeadSysOrder"
                android:layout_width="60dp"
                android:layout_height="24dp"
                android:text="系统派单"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />

            <!-- 综合上站APP -->
            <TextView
                android:id="@+id/tvHeadAppOrder"
                android:layout_width="70dp"
                android:layout_height="24dp"
                android:text="综合上站APP"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />

            <!-- 非综合上站 -->
            <TextView
                android:id="@+id/tvHeadOtherOrder"
                android:layout_width="70dp"
                android:layout_height="24dp"
                android:text="非综合上站"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />

            <!-- 单日单站回单 -->
            <TextView
                android:id="@+id/tvHeadDailyReply"
                android:layout_width="70dp"
                android:layout_height="24dp"
                android:text="单日单站回单"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />

            <!-- 综合上站效能 -->
            <TextView
                android:id="@+id/tvHeadEfficiency"
                android:layout_width="70dp"
                android:layout_height="24dp"
                android:text="综合上站效能"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />

            <!-- 代维公司 -->
            <TextView
                android:id="@+id/tvHeadDw"
                android:layout_width="50dp"
                android:layout_height="24dp"
                android:text="代维"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- 列表（水平滚动） -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="horizontal">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvReport"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:clipToPadding="false" />
    </HorizontalScrollView>

    <!-- 空状态 -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:text="暂无报表数据"
        android:visibility="gone" />

</LinearLayout>
