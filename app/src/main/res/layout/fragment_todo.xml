<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FB">

    <!-- ══ 顶部标题栏 ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="我的待办"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1E293B" />

        <!-- 新增按钮 -->
        <Button
            android:id="@+id/btnAddTodo"
            android:layout_width="80dp"
            android:layout_height="36dp"
            android:text="+ 新增"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_primary"
            android:stateListAnimator="@null"
            android:letterSpacing="0" />
    </LinearLayout>

    <!-- ══ 待办/已办 Tab 切换 ══ -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabTodo"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="#FFFFFF"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabTextAppearance="@style/TabTextStyle"
        app:tabSelectedTextColor="#4F46E5"
        app:tabTextColor="#64748B"
        app:tabIndicatorColor="#4F46E5"
        app:tabIndicatorHeight="2dp" />

    <!-- ══ 云同步状态栏 ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="#F8FAFC">

        <ProgressBar
            android:id="@+id/progressSync"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:visibility="gone"
            android:indeterminateTint="#4F46E5" />

        <TextView
            android:id="@+id/tvSyncStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="11sp"
            android:textColor="#94A3B8"
            android:visibility="gone"
            android:text="同步状态" />

    </LinearLayout>

    <!-- ══ 列表区域 ══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTodo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <!-- 空状态提示 -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="暂无事项，点击「+ 新增」添加"
        android:textSize="14sp"
        android:textColor="#94A3B8"
        android:visibility="gone" />

</LinearLayout>
