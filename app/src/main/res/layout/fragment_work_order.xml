<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_base">

    <!-- ======== 控制面板 CardView ======== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/bg_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <!-- ── 行1：开关组 + 操作按钮 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/cbAutoFeedback"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="自动反馈"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:buttonTint="@color/colorPrimary"
                    android:checked="true"
                    android:minHeight="0dp"
                    android:gravity="center_vertical"/>

                <CheckBox
                    android:id="@+id/cbAutoAccept"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="自动接单"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:buttonTint="@color/colorPrimary"
                    android:checked="true"
                    android:minHeight="0dp"
                    android:gravity="center_vertical"/>

                <CheckBox
                    android:id="@+id/cbAutoRevert"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="自动回单"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:buttonTint="@color/colorPrimary"
                    android:checked="true"
                    android:minHeight="0dp"
                    android:gravity="center_vertical"/>

                <Button
                    android:id="@+id/btnStartMonitor"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1.3"
                    android:layout_marginStart="4dp"
                    android:text="开启监控"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_inverse"
                    android:background="@drawable/bg_button_primary_gradient"
                    android:stateListAnimator="@null"
                    android:letterSpacing="0"/>

                <Button
                    android:id="@+id/btnStopMonitor"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="0.8"
                    android:layout_marginStart="4dp"
                    android:text="停止"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_inverse"
                    android:background="@drawable/bg_button_gray"
                    android:stateListAnimator="@null"
                    android:letterSpacing="0"/>
            </LinearLayout>

            <!-- 细分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="8dp"/>

            <!-- ── 行2：参数配置行 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 轮询 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="轮询"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"/>

                <EditText
                    android:id="@+id/etIntervalMin"
                    android:layout_width="32dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_input_white"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:text="90"
                    android:textColor="@color/text_primary"
                    android:textSize="9sp"
                    android:inputType="number"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="~"
                    android:textColor="@color/text_tertiary"
                    android:textSize="9sp"
                    android:layout_marginStart="1dp"/>

                <EditText
                    android:id="@+id/etIntervalMax"
                    android:layout_width="32dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="1dp"
                    android:background="@drawable/bg_input_white"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:text="120"
                    android:textColor="@color/text_primary"
                    android:textSize="9sp"
                    android:inputType="number"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="秒"
                    android:textColor="@color/text_tertiary"
                    android:textSize="9sp"
                    android:layout_marginStart="2dp"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="10dp"
                    android:background="@color/divider_strong"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"/>

                <!-- 反馈延迟 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="反馈"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"/>

                <EditText
                    android:id="@+id/etFeedbackMin"
                    android:layout_width="28dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_input_white"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:text="70"
                    android:textColor="@color/text_primary"
                    android:textSize="9sp"
                    android:inputType="number"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="~"
                    android:textColor="@color/text_tertiary"
                    android:textSize="9sp"
                    android:layout_marginStart="1dp"/>

                <EditText
                    android:id="@+id/etFeedbackMax"
                    android:layout_width="28dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="1dp"
                    android:background="@drawable/bg_input_white"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:text="90"
                    android:textColor="@color/text_primary"
                    android:textSize="9sp"
                    android:inputType="number"
                    android:gravity="center"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="10dp"
                    android:background="@color/divider_strong"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"/>

                <!-- 接单延迟 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="接单"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"/>

                <EditText
                    android:id="@+id/etAcceptMin"
                    android:layout_width="28dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_input_white"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:text="60"
                    android:textColor="@color/text_primary"
                    android:textSize="9sp"
                    android:inputType="number"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="~"
                    android:textColor="@color/text_tertiary"
                    android:textSize="9sp"
                    android:layout_marginStart="1dp"/>

                <EditText
                    android:id="@+id/etAcceptMax"
                    android:layout_width="28dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="1dp"
                    android:background="@drawable/bg_input_white"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:text="90"
                    android:textColor="@color/text_primary"
                    android:textSize="9sp"
                    android:inputType="number"
                    android:gravity="center"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ======== 排序工具栏 ======== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="@color/background_secondary"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="排序"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:letterSpacing="0.02"/>

        <View
            android:layout_width="1dp"
            android:layout_height="10dp"
            android:background="@color/divider_strong"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"/>

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/btnSortBillTime"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:text="工单历时 ↓"
                    android:textSize="10sp"
                    android:textColor="@color/text_inverse"
                    android:background="@drawable/bg_tag_primary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/btnSortFeedbackTime"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:text="反馈历时 ↕"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_inactive"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:layout_marginStart="6dp"/>

                <TextView
                    android:id="@+id/btnSortAlertTime"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:text="告警时间 ↕"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_inactive"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:layout_marginStart="6dp"/>

                <TextView
                    android:id="@+id/btnSortAcceptor"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:text="接单人 ↕"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_inactive"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:layout_marginStart="6dp"/>

                <TextView
                    android:id="@+id/btnSortAlertStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:text="告警状态 ↕"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_inactive"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_strong"/>

    <!-- ======== 工单列表 ======== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerWorkOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background_primary"
        android:clipToPadding="false"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"/>

</LinearLayout>
