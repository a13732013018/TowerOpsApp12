<?xml version="1.0" encoding="utf-8"?>
<!-- 优化版工单监控界面 - ConstraintLayout布局，更丝滑的交互 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <!-- ===== 优化控制面板 CardView ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/controlPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/bg_card"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 使用优化布局减少嵌套 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <!-- 开关组 - 链式布局 -->
            <CheckBox
                android:id="@+id/cbAutoFeedback"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:text="自动反馈"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:buttonTint="@color/colorPrimary"
                android:checked="true"
                android:minHeight="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/cbAutoAccept"
                app:layout_constraintHorizontal_chainStyle="spread"/>

            <CheckBox
                android:id="@+id/cbAutoAccept"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:text="自动接单"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:buttonTint="@color/colorPrimary"
                android:checked="true"
                android:minHeight="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@+id/cbAutoFeedback"
                app:layout_constraintEnd_toStartOf="@+id/cbAutoRevert"/>

            <CheckBox
                android:id="@+id/cbAutoRevert"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:text="自动回单"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:buttonTint="@color/colorPrimary"
                android:checked="true"
                android:minHeight="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@+id/cbAutoAccept"
                app:layout_constraintEnd_toStartOf="@+id/btnStartMonitor"/>

            <!-- 按钮组 -->
            <Button
                android:id="@+id/btnStartMonitor"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:text="开启监控"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/text_inverse"
                android:background="@drawable/bg_button_primary_gradient"
                android:stateListAnimator="@null"
                android:letterSpacing="0"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@+id/cbAutoRevert"
                app:layout_constraintEnd_toStartOf="@+id/btnStopMonitor"/>

            <Button
                android:id="@+id/btnStopMonitor"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:text="停止"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/text_inverse"
                android:background="@drawable/bg_button_gray"
                android:stateListAnimator="@null"
                android:letterSpacing="0"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@+id/btnStartMonitor"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- 分割线 -->
            <View
                android:id="@+id/dividerControls"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@+id/cbAutoFeedback"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- 参数配置行 - ConstraintLayout优化 -->
            <TextView
                android:id="@+id/labelPoll"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="轮询"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@+id/dividerControls"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etIntervalMin"
                android:layout_width="32dp"
                android:layout_height="22dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_input_white"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="90"
                android:textColor="@color/text_primary"
                android:textSize="9sp"
                android:inputType="number"
                android:gravity="center"
                android:importantForAutofill="no"
                app:layout_constraintTop_toTopOf="@+id/labelPoll"
                app:layout_constraintBottom_toBottomOf="@+id/labelPoll"
                app:layout_constraintStart_toEndOf="@+id/labelPoll"/>

            <TextView
                android:id="@+id/labelTilde1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~"
                android:textColor="@color/text_tertiary"
                android:textSize="9sp"
                android:layout_marginStart="1dp"
                app:layout_constraintTop_toTopOf="@+id/labelPoll"
                app:layout_constraintBottom_toBottomOf="@+id/labelPoll"
                app:layout_constraintStart_toEndOf="@+id/etIntervalMin"/>

            <EditText
                android:id="@+id/etIntervalMax"
                android:layout_width="32dp"
                android:layout_height="22dp"
                android:layout_marginStart="1dp"
                android:background="@drawable/bg_input_white"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="120"
                android:textColor="@color/text_primary"
                android:textSize="9sp"
                android:inputType="number"
                android:gravity="center"
                android:importantForAutofill="no"
                app:layout_constraintTop_toTopOf="@+id/labelTilde1"
                app:layout_constraintBottom_toBottomOf="@+id/labelTilde1"
                app:layout_constraintStart_toEndOf="@+id/labelTilde1"/>

            <TextView
                android:id="@+id/labelSec1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="秒"
                android:textColor="@color/text_tertiary"
                android:textSize="9sp"
                android:layout_marginStart="2dp"
                app:layout_constraintTop_toTopOf="@+id/labelPoll"
                app:layout_constraintBottom_toBottomOf="@+id/labelPoll"
                app:layout_constraintStart_toEndOf="@+id/etIntervalMax"/>

            <!-- 分割竖线 -->
            <View
                android:id="@+id/divider1"
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:background="@color/divider_strong"
                android:layout_marginStart="8dp"
                app:layout_constraintTop_toTopOf="@+id/labelPoll"
                app:layout_constraintBottom_toBottomOf="@+id/labelPoll"
                app:layout_constraintStart_toEndOf="@+id/labelSec1"/>

            <!-- 反馈延迟 -->
            <TextView
                android:id="@+id/labelFeedback"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="反馈"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:gravity="center_vertical"
                android:layout_marginStart="8dp"
                app:layout_constraintTop_toTopOf="@+id/labelPoll"
                app:layout_constraintBottom_toBottomOf="@+id/labelPoll"
                app:layout_constraintStart_toEndOf="@+id/divider1"/>

            <EditText
                android:id="@+id/etFeedbackMin"
                android:layout_width="28dp"
                android:layout_height="22dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_input_white"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="70"
                android:textColor="@color/text_primary"
                android:textSize="9sp"
                android:inputType="number"
                android:gravity="center"
                android:importantForAutofill="no"
                app:layout_constraintTop_toTopOf="@+id/labelFeedback"
                app:layout_constraintBottom_toBottomOf="@+id/labelFeedback"
                app:layout_constraintStart_toEndOf="@+id/labelFeedback"/>

            <TextView
                android:id="@+id/labelTilde2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~"
                android:textColor="@color/text_tertiary"
                android:textSize="9sp"
                android:layout_marginStart="1dp"
                app:layout_constraintTop_toTopOf="@+id/labelFeedback"
                app:layout_constraintBottom_toBottomOf="@+id/labelFeedback"
                app:layout_constraintStart_toEndOf="@+id/etFeedbackMin"/>

            <EditText
                android:id="@+id/etFeedbackMax"
                android:layout_width="28dp"
                android:layout_height="22dp"
                android:layout_marginStart="1dp"
                android:background="@drawable/bg_input_white"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="90"
                android:textColor="@color/text_primary"
                android:textSize="9sp"
                android:inputType="number"
                android:gravity="center"
                android:importantForAutofill="no"
                app:layout_constraintTop_toTopOf="@+id/labelTilde2"
                app:layout_constraintBottom_toBottomOf="@+id/labelTilde2"
                app:layout_constraintStart_toEndOf="@+id/labelTilde2"/>

            <!-- 分割竖线2 -->
            <View
                android:id="@+id/divider2"
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:background="@color/divider_strong"
                android:layout_marginStart="8dp"
                app:layout_constraintTop_toTopOf="@+id/labelFeedback"
                app:layout_constraintBottom_toBottomOf="@+id/labelFeedback"
                app:layout_constraintStart_toEndOf="@+id/etFeedbackMax"/>

            <!-- 接单延迟 -->
            <TextView
                android:id="@+id/labelAccept"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="接单"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:gravity="center_vertical"
                android:layout_marginStart="8dp"
                app:layout_constraintTop_toTopOf="@+id/divider2"
                app:layout_constraintBottom_toBottomOf="@+id/divider2"
                app:layout_constraintStart_toEndOf="@+id/divider2"/>

            <EditText
                android:id="@+id/etAcceptMin"
                android:layout_width="28dp"
                android:layout_height="22dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_input_white"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="60"
                android:textColor="@color/text_primary"
                android:textSize="9sp"
                android:inputType="number"
                android:gravity="center"
                android:importantForAutofill="no"
                app:layout_constraintTop_toTopOf="@+id/labelAccept"
                app:layout_constraintBottom_toBottomOf="@+id/labelAccept"
                app:layout_constraintStart_toEndOf="@+id/labelAccept"/>

            <TextView
                android:id="@+id/labelTilde3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~"
                android:textColor="@color/text_tertiary"
                android:textSize="9sp"
                android:layout_marginStart="1dp"
                app:layout_constraintTop_toTopOf="@+id/labelAccept"
                app:layout_constraintBottom_toBottomOf="@+id/labelAccept"
                app:layout_constraintStart_toEndOf="@+id/etAcceptMin"/>

            <EditText
                android:id="@+id/etAcceptMax"
                android:layout_width="28dp"
                android:layout_height="22dp"
                android:layout_marginStart="1dp"
                android:background="@drawable/bg_input_white"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="90"
                android:textColor="@color/text_primary"
                android:textSize="9sp"
                android:inputType="number"
                android:gravity="center"
                android:importantForAutofill="no"
                app:layout_constraintTop_toTopOf="@+id/labelTilde3"
                app:layout_constraintBottom_toBottomOf="@+id/labelTilde3"
                app:layout_constraintStart_toEndOf="@+id/labelTilde3"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===== 优化排序工具栏 ===== -->
    <LinearLayout
        android:id="@+id/sortToolbar"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="@color/background_secondary"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@+id/controlPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="排序"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:letterSpacing="0.02"/>

        <View
            android:layout_width="1dp"
            android:layout_height="10dp"
            android:background="@color/divider_strong"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"/>

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 排序按钮 - 使用优化样式 -->
                <TextView
                    android:id="@+id/btnSortBillTime"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:text="工单历时 ↓"
                    android:textSize="10sp"
                    android:textColor="@color/text_inverse"
                    android:background="@drawable/bg_tag_primary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/btnSortFeedbackTime"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:text="反馈历时 ↕"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_inactive"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:layout_marginStart="6dp"/>

                <TextView
                    android:id="@+id/btnSortAlertTime"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:text="告警时间 ↕"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_inactive"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:layout_marginStart="6dp"/>

                <TextView
                    android:id="@+id/btnSortAcceptor"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:text="接单人 ↕"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_inactive"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:layout_marginStart="6dp"/>

                <TextView
                    android:id="@+id/btnSortAlertStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:text="告警状态 ↕"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_inactive"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- 底部分割线 -->
    <View
        android:id="@+id/dividerSort"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider_strong"
        app:layout_constraintTop_toBottomOf="@+id/sortToolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ===== 优化工单列表 ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerWorkOrders"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/background_primary"
        android:clipToPadding="false"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@+id/dividerSort"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
