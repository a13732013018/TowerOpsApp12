<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- 顶部子Tab栏 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:background="@color/background_secondary"
        android:scrollbars="none"
        android:fillViewport="true"
        android:elevation="1dp">

        <LinearLayout
            android:id="@+id/tabBarXunjian"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/tabXunjianUnstart"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="未巡检"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:background="@drawable/bg_tag_inactive"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tabXunjianZhilian"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="智联巡检"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:background="@drawable/bg_tag_inactive"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tabXunjianQuality"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="APP质检"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:background="@drawable/bg_tag_inactive"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- 内容区（ViewFlipper）-->
    <ViewFlipper
        android:id="@+id/viewFlipperXunjian"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Panel 0: 未巡检工单 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/background_primary">

            <!-- 操作栏 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="10dp"
                android:background="@color/background_secondary"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvUnstartCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="未巡检: 0 条"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btnQueryUnstart"
                    android:layout_width="72dp"
                    android:layout_height="30dp"
                    android:text="查询"
                    android:textSize="12sp"
                    android:backgroundTint="@color/colorPrimary"
                    android:textColor="@android:color/white"
                    android:includeFontPadding="false"
                    android:stateListAnimator="@null"
                    android:letterSpacing="0"/>
            </LinearLayout>

            <!-- 未巡检列表表头 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:orientation="horizontal"
                android:background="@color/background_tertiary"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <TextView android:id="@+id/thUnstartSeq"
                    android:layout_width="28dp" android:layout_height="match_parent"
                    android:text="序" android:textSize="9sp" android:gravity="center" android:textColor="@color/text_secondary"
                    android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                <TextView android:id="@+id/thUnstartGroup"
                    android:layout_width="48dp" android:layout_height="match_parent"
                    android:text="分组" android:textSize="9sp" android:gravity="center" android:textColor="@color/text_secondary"
                    android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                <TextView android:id="@+id/thUnstartTasksn"
                    android:layout_width="76dp" android:layout_height="match_parent"
                    android:text="工单号" android:textSize="9sp" android:gravity="center" android:textColor="@color/text_secondary"
                    android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                <TextView android:id="@+id/thUnstartStation"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="站点名" android:textSize="9sp" android:gravity="center" android:textColor="@color/text_secondary"
                    android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                <TextView android:id="@+id/thUnstartMajor"
                    android:layout_width="46dp" android:layout_height="match_parent"
                    android:text="专业" android:textSize="9sp" android:gravity="center" android:textColor="@color/text_secondary"
                    android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                <TextView android:id="@+id/thUnstartDate"
                    android:layout_width="56dp" android:layout_height="match_parent"
                    android:text="日期" android:textSize="9sp" android:gravity="center" android:textColor="@color/text_secondary"
                    android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- 未巡检列表 -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <LinearLayout
                    android:id="@+id/llUnstartList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </ScrollView>

            <!-- 专业统计 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/background_secondary"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="专业统计"
                    android:textSize="10sp"
                    android:textColor="@color/text_tertiary"
                    android:paddingBottom="3dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:orientation="horizontal"
                    android:background="@color/background_tertiary">
                    <TextView android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:text="机房" android:textSize="9sp" android:textColor="@color/text_secondary" android:gravity="center" android:includeFontPadding="false"/>
                    <TextView android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:text="机柜" android:textSize="9sp" android:textColor="@color/text_secondary" android:gravity="center" android:includeFontPadding="false"/>
                    <TextView android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:text="拉远" android:textSize="9sp" android:textColor="@color/text_secondary" android:gravity="center" android:includeFontPadding="false"/>
                    <TextView android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:text="铁塔" android:textSize="9sp" android:textColor="@color/text_secondary" android:gravity="center" android:includeFontPadding="false"/>
                    <TextView android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:text="室分" android:textSize="9sp" android:textColor="@color/text_secondary" android:gravity="center" android:includeFontPadding="false"/>
                    <TextView android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:text="其他" android:textSize="9sp" android:textColor="@color/text_secondary" android:gravity="center" android:includeFontPadding="false"/>
                    <TextView android:layout_width="38dp" android:layout_height="match_parent"
                        android:text="合计" android:textSize="9sp" android:textColor="@color/text_secondary" android:gravity="center" android:includeFontPadding="false"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llUnstartStat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Panel 1: 智联巡检 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/background_primary">

            <!-- 操作栏 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="10dp"
                android:background="@color/background_secondary"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvZhilianXunjianCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="智联巡检: 0 条"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btnQueryZhilianXunjian"
                    android:layout_width="72dp"
                    android:layout_height="30dp"
                    android:text="查询"
                    android:textSize="12sp"
                    android:backgroundTint="@color/colorPrimary"
                    android:textColor="@android:color/white"
                    android:includeFontPadding="false"
                    android:stateListAnimator="@null"
                    android:letterSpacing="0"/>
            </LinearLayout>

            <!-- 智联巡检表头 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:orientation="horizontal"
                android:background="@color/background_tertiary"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <TextView android:id="@+id/thZhilianSeq"
                    android:layout_width="28dp" android:layout_height="match_parent"
                    android:text="序" android:textSize="9sp" android:gravity="center" android:textColor="@color/text_secondary"
                    android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                <TextView android:id="@+id/thZhilianGroup"
                    android:layout_width="48dp" android:layout_height="match_parent"
                    android:text="分组" android:textSize="9sp" android:gravity="center" android:textColor="@color/text_secondary"
                    android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                <TextView android:id="@+id/thZhilianTasksn"
                    android:layout_width="76dp" android:layout_height="match_parent"
                    android:text="工单号" android:textSize="9sp" android:gravity="center" android:textColor="@color/text_secondary"
                    android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                <TextView android:id="@+id/thZhilianStation"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="站点名" android:textSize="9sp" android:gravity="center" android:textColor="@color/text_secondary"
                    android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                <TextView android:id="@+id/thZhilianMajor"
                    android:layout_width="46dp" android:layout_height="match_parent"
                    android:text="专业" android:textSize="9sp" android:gravity="center" android:textColor="@color/text_secondary"
                    android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                <TextView android:id="@+id/thZhilianCreatetime"
                    android:layout_width="96dp" android:layout_height="match_parent"
                    android:text="创建时间" android:textSize="9sp" android:gravity="center" android:textColor="@color/text_secondary"
                    android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- 智联巡检列表 -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:id="@+id/llZhilianXunjianList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </ScrollView>

        </LinearLayout>

        <!-- Panel 2: APP巡检质检 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/background_primary">

            <!-- 查询控制栏 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/background_secondary"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <!-- 第一行：计划年+查询按钮 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="计划年"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginEnd="5dp"/>

                    <Spinner
                        android:id="@+id/spinnerPlanYear"
                        android:layout_width="0dp"
                        android:layout_height="28dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_edittext"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"/>

                    <Button
                        android:id="@+id/btnQueryQuality"
                        android:layout_width="66dp"
                        android:layout_height="30dp"
                        android:text="查询"
                        android:textSize="12sp"
                        android:backgroundTint="@color/colorPrimary"
                        android:textColor="@android:color/white"
                        android:layout_marginStart="8dp"
                        android:includeFontPadding="false"
                        android:stateListAnimator="@null"
                        android:letterSpacing="0"/>
                </LinearLayout>

                <!-- 第二行：年月+勾选 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="年"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginEnd="4dp"/>

                    <Spinner
                        android:id="@+id/spinnerQualityYear"
                        android:layout_width="76dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_edittext"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="月"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="4dp"/>

                    <Spinner
                        android:id="@+id/spinnerQualityMonth"
                        android:layout_width="56dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_edittext"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"/>

                    <CheckBox
                        android:id="@+id/cbShowAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="全显"
                        android:textSize="11sp"
                        android:layout_marginStart="8dp"
                        android:minHeight="0dp"
                        android:checked="true"/>

                    <CheckBox
                        android:id="@+id/cbQualityByMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="按月"
                        android:textSize="11sp"
                        android:layout_marginStart="8dp"
                        android:minHeight="0dp"
                        android:checked="false"/>

                    <CheckBox
                        android:id="@+id/cbQualityToday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="今日"
                        android:textSize="11sp"
                        android:layout_marginStart="8dp"
                        android:minHeight="0dp"
                        android:checked="false"/>

                </LinearLayout>

                <!-- 第三行：进度条 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="进度"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"/>

                    <ProgressBar
                        android:id="@+id/progressQuality"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="14dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="@color/colorPrimary"
                        android:progressBackgroundTint="#D1D5DB"/>

                    <TextView
                        android:id="@+id/tvQualityProgress"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="@color/colorPrimary"
                        android:textStyle="bold"
                        android:gravity="center"/>

                </LinearLayout>
            </LinearLayout>

            <!-- 子Tab：任务列表 / 质检详情 / 统计报表 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:orientation="horizontal"
                android:background="@color/background_tertiary">

                <TextView
                    android:id="@+id/tabQualityTask"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="任务列表"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:textColor="@color/colorPrimary"
                    android:background="@color/background_secondary"
                    android:clickable="true"
                    android:focusable="true"/>

                <View android:layout_width="0.5dp" android:layout_height="match_parent" android:background="@color/divider"/>

                <TextView
                    android:id="@+id/tabQualityDetail"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="质检详情"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:textColor="@color/text_secondary"
                    android:clickable="true"
                    android:focusable="true"/>

                <View android:layout_width="0.5dp" android:layout_height="match_parent" android:background="@color/divider"/>

                <TextView
                    android:id="@+id/tabQualityReport"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="统计报表"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:textColor="@color/text_secondary"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- 质检内容区 ViewFlipper -->
            <ViewFlipper
                android:id="@+id/viewFlipperQuality"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- 任务列表 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="22dp"
                        android:orientation="horizontal"
                        android:background="@color/background_tertiary"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp">
                        <TextView android:id="@+id/thTaskSeq"
                            android:layout_width="28dp" android:layout_height="match_parent"
                            android:text="序" android:textSize="8sp" android:gravity="center" android:textColor="@color/text_secondary"
                            android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                        <TextView android:id="@+id/thTaskGroup"
                            android:layout_width="42dp" android:layout_height="match_parent"
                            android:text="分组" android:textSize="8sp" android:gravity="center" android:textColor="@color/text_secondary"
                            android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                        <TextView android:id="@+id/thTaskStation"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="站点" android:textSize="8sp" android:gravity="center" android:textColor="@color/text_secondary"
                            android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                        <TextView android:id="@+id/thTaskMajor"
                            android:layout_width="38dp" android:layout_height="match_parent"
                            android:text="专业" android:textSize="8sp" android:gravity="center" android:textColor="@color/text_secondary"
                            android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                        <TextView android:id="@+id/thTaskProgress"
                            android:layout_width="52dp" android:layout_height="match_parent"
                            android:text="进度" android:textSize="8sp" android:gravity="center" android:textColor="@color/text_secondary"
                            android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                        <TextView android:id="@+id/thTaskStart"
                            android:layout_width="86dp" android:layout_height="match_parent"
                            android:text="开始时间" android:textSize="8sp" android:gravity="center" android:textColor="@color/text_secondary"
                            android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                        <TextView android:id="@+id/thTaskEnd"
                            android:layout_width="86dp" android:layout_height="match_parent"
                            android:text="结束时间" android:textSize="8sp" android:gravity="center" android:textColor="@color/text_secondary"
                            android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                    </LinearLayout>

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <LinearLayout
                            android:id="@+id/llQualityTaskList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>
                    </ScrollView>
                </LinearLayout>

                <!-- 质检详情 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="22dp"
                        android:orientation="horizontal"
                        android:background="@color/background_tertiary"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp">
                        <TextView android:id="@+id/thDetailSeq"
                            android:layout_width="28dp" android:layout_height="match_parent"
                            android:text="序" android:textSize="8sp" android:gravity="center" android:textColor="@color/text_secondary"
                            android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                        <TextView android:id="@+id/thDetailGroup"
                            android:layout_width="42dp" android:layout_height="match_parent"
                            android:text="分组" android:textSize="8sp" android:gravity="center" android:textColor="@color/text_secondary"
                            android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                        <TextView android:id="@+id/thDetailStation"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="站点" android:textSize="8sp" android:gravity="center" android:textColor="@color/text_secondary"
                            android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                        <TextView android:id="@+id/thDetailMajor"
                            android:layout_width="42dp" android:layout_height="match_parent"
                            android:text="专业" android:textSize="8sp" android:gravity="center" android:textColor="@color/text_secondary"
                            android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                        <TextView android:id="@+id/thDetailProject"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="巡检项目" android:textSize="8sp" android:gravity="center" android:textColor="@color/text_secondary"
                            android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                        <TextView android:id="@+id/thDetailResult"
                            android:layout_width="42dp" android:layout_height="match_parent"
                            android:text="结果" android:textSize="8sp" android:gravity="center" android:textColor="@color/text_secondary"
                            android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                        <TextView android:id="@+id/thDetailPass"
                            android:layout_width="30dp" android:layout_height="match_parent"
                            android:text="质检" android:textSize="8sp" android:gravity="center" android:textColor="@color/text_secondary"
                            android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                        <TextView android:id="@+id/thDetailReason"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="质检问题" android:textSize="8sp" android:gravity="center" android:textColor="@color/text_secondary"
                            android:clickable="true" android:focusable="true" android:includeFontPadding="false"/>
                    </LinearLayout>

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <LinearLayout
                            android:id="@+id/llQualityDetailList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>
                    </ScrollView>
                </LinearLayout>

                <!-- 统计报表 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="6dp"
                    android:background="@color/background_primary">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="22dp"
                        android:orientation="horizontal"
                        android:background="@color/colorPrimary">
                        <TextView android:layout_width="48dp" android:layout_height="match_parent"
                            android:text="分组" android:textSize="9sp" android:textColor="#FFFFFF" android:gravity="center" android:includeFontPadding="false"/>
                        <TextView android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="成员" android:textSize="9sp" android:textColor="#FFFFFF" android:gravity="center" android:includeFontPadding="false"/>
                        <TextView android:layout_width="40dp" android:layout_height="match_parent"
                            android:text="机房" android:textSize="9sp" android:textColor="#FFFFFF" android:gravity="center" android:includeFontPadding="false"/>
                        <TextView android:layout_width="40dp" android:layout_height="match_parent"
                            android:text="机柜" android:textSize="9sp" android:textColor="#FFFFFF" android:gravity="center" android:includeFontPadding="false"/>
                        <TextView android:layout_width="40dp" android:layout_height="match_parent"
                            android:text="拉远" android:textSize="9sp" android:textColor="#FFFFFF" android:gravity="center" android:includeFontPadding="false"/>
                        <TextView android:layout_width="40dp" android:layout_height="match_parent"
                            android:text="铁塔" android:textSize="9sp" android:textColor="#FFFFFF" android:gravity="center" android:includeFontPadding="false"/>
                        <TextView android:layout_width="34dp" android:layout_height="match_parent"
                            android:text="今日机" android:textSize="8sp" android:textColor="#FFFFFF" android:gravity="center" android:includeFontPadding="false"/>
                        <TextView android:layout_width="34dp" android:layout_height="match_parent"
                            android:text="今日塔" android:textSize="8sp" android:textColor="#FFFFFF" android:gravity="center" android:includeFontPadding="false"/>
                        <TextView android:layout_width="34dp" android:layout_height="match_parent"
                            android:text="合计" android:textSize="9sp" android:textColor="#FFFFFF" android:gravity="center" android:includeFontPadding="false"/>
                        <TextView android:layout_width="40dp" android:layout_height="match_parent"
                            android:text="机房%" android:textSize="8sp" android:textColor="#FFFFFF" android:gravity="center" android:includeFontPadding="false"/>
                        <TextView android:layout_width="40dp" android:layout_height="match_parent"
                            android:text="铁塔%" android:textSize="8sp" android:textColor="#FFFFFF" android:gravity="center" android:includeFontPadding="false"/>
                    </LinearLayout>

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <LinearLayout
                            android:id="@+id/llQualityReport"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>
                    </ScrollView>
                </LinearLayout>

            </ViewFlipper>
        </LinearLayout>

    </ViewFlipper>

</LinearLayout>
