<?xml version="1.0" encoding="utf-8"?>
<!--
  智联工单 Fragment v5.0
  设计规范：
  ├── 卡片系统：margin 10dp，cornerRadius 14dp，elevation 2dp
  ├── 控制面板：48dp 单行高，按钮 36dp
  ├── 子Tab：40dp 高，3dp 指示器
  ├── 列表：layout_weight=1 全占
  └── 日志区：固定 120dp，含22dp标题栏
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_base">

    <!-- ═══ 控制面板卡片 ═══ -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/bg_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- 状态行：高 32dp -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <!-- 状态文字 -->
                <TextView
                    android:id="@+id/tvZhilianStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="智联监控未启动"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:includeFontPadding="false"/>

                <!-- 时钟：monospace -->
                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--:--"
                    android:textSize="12sp"
                    android:textColor="@color/text_tertiary"
                    android:fontFamily="monospace"
                    android:layout_marginEnd="10dp"
                    android:includeFontPadding="false"/>

                <!-- 未领取 chip：精准 26dp 高，圆角 13dp，靛蓝浅底 -->
                <TextView
                    android:id="@+id/tvUnclaimedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="未领: 0"
                    android:textSize="10sp"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"
                    android:background="@color/primary_light"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:layout_marginEnd="6dp"
                    android:includeFontPadding="false"/>

                <!-- 已领取 chip：绿色浅底 -->
                <TextView
                    android:id="@+id/tvClaimedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="已领: 0"
                    android:textSize="10sp"
                    android:textColor="@color/success"
                    android:textStyle="bold"
                    android:background="@color/success_light"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="10dp"/>

            <!-- 控制行：高 36dp，所有按钮统一 36dp -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <CheckBox
                    android:id="@+id/cbAutoAccept"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="自动接单"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:buttonTint="@color/colorPrimary"
                    android:checked="true"
                    android:minHeight="0dp"
                    android:gravity="center_vertical"/>

                <ImageView
                    android:id="@+id/ivAutoAcceptInfo"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="2dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    android:tint="@color/text_tertiary"/>

                <CheckBox
                    android:id="@+id/cbAutoRevert"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="自动回单"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:buttonTint="@color/colorPrimary"
                    android:checked="true"
                    android:layout_marginStart="6dp"
                    android:minHeight="0dp"
                    android:gravity="center_vertical"/>

                <ImageView
                    android:id="@+id/ivAutoRevertInfo"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="2dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    android:tint="@color/text_tertiary"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <!-- 启动按钮：36dp 高，精准宽度 -->
                <Button
                    android:id="@+id/btnStartZhilian"
                    android:layout_width="72dp"
                    android:layout_height="36dp"
                    android:text="启动监控"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_primary_gradient"
                    android:textColor="@color/text_inverse"
                    android:stateListAnimator="@null"
                    android:minHeight="0dp"
                    android:letterSpacing="0"
                    android:padding="0dp"/>

                <!-- 停止按钮：36dp 高 -->
                <Button
                    android:id="@+id/btnStopZhilian"
                    android:layout_width="52dp"
                    android:layout_height="36dp"
                    android:text="停止"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/btn_secondary"
                    android:textColor="@color/text_inverse"
                    android:layout_marginStart="6dp"
                    android:enabled="false"
                    android:stateListAnimator="@null"
                    android:minHeight="0dp"
                    android:letterSpacing="0"
                    android:padding="0dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══ 子 Tab：40dp 高 ═══ -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutZhilian"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@color/bg_card"
        app:tabIndicatorColor="@color/colorPrimary"
        app:tabSelectedTextColor="@color/colorPrimary"
        app:tabTextColor="@color/tab_unselected"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorHeight="3dp"
        app:tabIndicatorFullWidth="false"
        app:tabTextAppearance="@style/TabTextStyle">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未领取"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="已领取"/>

    </com.google.android.material.tabs.TabLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_strong"/>

    <!-- ═══ 列表区：layout_weight=1 撑满 ═══ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvUnclaimed"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false"
            android:visibility="visible"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvClaimed"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="暂无数据"
            android:textSize="13sp"
            android:textColor="@color/text_tertiary"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- ═══ 日志面板：精工 120dp · 高级感 ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:orientation="vertical"
        android:background="@color/log_background">

        <!-- 顶部细线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/log_border"/>

        <!-- 标题栏：24dp 高 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@color/log_header_bg"
            android:gravity="center_vertical">

            <!-- macOS 三色圆点，精准 8dp -->
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_circle_red"
                android:layout_marginEnd="5dp"/>
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_circle_yellow"
                android:layout_marginEnd="5dp"/>
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_circle_green"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="运行日志"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/log_title"
                android:fontFamily="monospace"
                android:includeFontPadding="false"/>

            <!-- LIVE badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:text="● LIVE"
                android:textSize="8sp"
                android:textColor="@color/success"
                android:textStyle="bold"
                android:background="@color/success_light"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:gravity="center"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <!-- 日志内容分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/log_border"/>

        <!-- 日志 ScrollView -->
        <ScrollView
            android:id="@+id/svLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="9.5sp"
                android:textColor="@color/log_text"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5"
                android:includeFontPadding="false"/>
        </ScrollView>
    </LinearLayout>

</LinearLayout>
