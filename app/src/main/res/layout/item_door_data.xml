<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="0dp">

    <!-- 数据行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:gravity="center_vertical">

        <!-- 序号 -->
        <TextView
            android:id="@+id/tvDoorIdx"
            android:layout_width="24dp"
            android:layout_height="wrap_content"
            android:textSize="9sp"
            android:textColor="#6B7280"
            android:text="1" />

        <!-- 站名 + 站码 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.8"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvDoorStName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#1E293B"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="某某站" />
            <TextView
                android:id="@+id/tvDoorStCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="#94A3B8"
                android:singleLine="true"
                android:text="" />
        </LinearLayout>

        <!-- 告警名 -->
        <TextView
            android:id="@+id/tvDoorAlarmName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.1"
            android:textSize="9sp"
            android:textColor="#374151"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="门磁异常" />

        <!-- 告警时间 -->
        <TextView
            android:id="@+id/tvDoorAlarmTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.3"
            android:textSize="9sp"
            android:textColor="#374151"
            android:includeFontPadding="false"
            android:text="03-29 10:00" />

        <!-- 蓝牙开门时间 -->
        <TextView
            android:id="@+id/tvDoorBtTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.3"
            android:textSize="9sp"
            android:textColor="#374151"
            android:includeFontPadding="false"
            android:text="无" />

        <!-- 远程开门时间 -->
        <TextView
            android:id="@+id/tvDoorRemoteTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.3"
            android:textSize="9sp"
            android:textColor="#374151"
            android:includeFontPadding="false"
            android:text="无" />

        <!-- 4A开门时间 -->
        <TextView
            android:id="@+id/tvDoor4ATime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.3"
            android:textSize="9sp"
            android:textColor="#374151"
            android:includeFontPadding="false"
            android:text="无" />

        <!-- 时差（分钟） -->
        <TextView
            android:id="@+id/tvDoorDiff"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:textSize="9sp"
            android:textColor="#6B7280"
            android:gravity="center"
            android:text="-" />

        <!-- 合格/不合格 -->
        <TextView
            android:id="@+id/tvDoorQualified"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="center"
            android:text="✓ 合格" />
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#E5E7EB" />
</LinearLayout>
