<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="44dp"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:gravity="center_vertical">

    <!-- 展开箭头 -->
    <TextView
        android:id="@+id/tvWorkerArrow"
        android:layout_width="16dp"
        android:layout_height="wrap_content"
        android:text="▶"
        android:textSize="9sp"
        android:textColor="#2563EB"
        android:gravity="center"/>

    <!-- 姓名 -->
    <TextView
        android:id="@+id/tvWorkerName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:singleLine="true"
        android:ellipsize="end"/>

    <!-- 条数（总/无效） -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">
        <TextView
            android:id="@+id/tvWorkerCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#374151"
            android:gravity="center"/>
        <TextView
            android:id="@+id/tvWorkerInvalidCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="9sp"
            android:textColor="#DC2626"
            android:gravity="center"/>
    </LinearLayout>

    <!-- 总费用 -->
    <TextView
        android:id="@+id/tvWorkerTotal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#2563EB"
        android:gravity="center"/>

    <!-- 有效 -->
    <TextView
        android:id="@+id/tvWorkerValid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:textSize="11sp"
        android:textColor="#16A34A"
        android:gravity="center"/>

    <!-- 无效 -->
    <TextView
        android:id="@+id/tvWorkerInvalid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:textSize="11sp"
        android:textColor="#374151"
        android:gravity="center"/>

</LinearLayout>
