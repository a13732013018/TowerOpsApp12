<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:gravity="center_vertical"
    android:background="#FFFFFF">

    <!-- 姓名 -->
    <TextView
        android:id="@+id/tvScName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.2"
        android:textSize="12sp"
        android:textColor="#111827"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="1"/>

    <!-- 天数 -->
    <TextView
        android:id="@+id/tvScDays"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="11sp"
        android:textColor="#374151"
        android:gravity="center"/>

    <!-- 次数 -->
    <TextView
        android:id="@+id/tvScCount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="11sp"
        android:textColor="#374151"
        android:gravity="center"/>

    <!-- 合格 -->
    <TextView
        android:id="@+id/tvScQualified"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="11sp"
        android:textColor="#16A34A"
        android:textStyle="bold"
        android:gravity="center"/>

    <!-- 不合格 -->
    <TextView
        android:id="@+id/tvScUnqualified"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="11sp"
        android:textColor="#DC2626"
        android:textStyle="bold"
        android:gravity="center"/>

    <!-- 合格率 -->
    <TextView
        android:id="@+id/tvScPassRate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.3"
        android:textSize="11sp"
        android:textColor="#2563EB"
        android:textStyle="bold"
        android:gravity="center"/>

    <!-- 平均时长 -->
    <TextView
        android:id="@+id/tvScAvgDuration"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:textSize="11sp"
        android:textColor="#374151"
        android:gravity="center"/>

</LinearLayout>
