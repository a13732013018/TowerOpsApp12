<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- 左侧优先级色条（4dp宽） -->
        <View
            android:id="@+id/viewPriorityBar"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_priority_bar_normal" />

        <!-- 主体内容区 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="10dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <!-- 完成/待办 状态圆圈 -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_todo_status_pending"
                android:text="" />

            <!-- 标题 + 标签行 + 备注 + 时间 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="6dp">

                <!-- 标题 -->
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <!-- 标签行：优先级标签 + 截止时间标签 -->
                <LinearLayout
                    android:id="@+id/llTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="5dp">

                    <!-- 优先级标签 -->
                    <TextView
                        android:id="@+id/tvPriorityTag"
                        android:layout_width="wrap_content"
                        android:layout_height="20dp"
                        android:gravity="center"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:background="@drawable/bg_tag_normal"
                        android:textColor="#4F46E5"
                        android:text="普通"
                        android:visibility="gone" />

                    <!-- 截止时间标签 -->
                    <TextView
                        android:id="@+id/tvDueTag"
                        android:layout_width="wrap_content"
                        android:layout_height="20dp"
                        android:gravity="center"
                        android:textSize="10sp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_tag_today"
                        android:textColor="#854D0E"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- 备注 -->
                <TextView
                    android:id="@+id/tvContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#64748B"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:visibility="gone"
                    android:layout_marginTop="3dp" />

                <!-- 创建/完成时间 -->
                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#94A3B8"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- 删除按钮 -->
            <TextView
                android:id="@+id/btnDelete"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="✕"
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
