<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/background_secondary"
    android:stateListAnimator="@android:animator/fade_in">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部彩色状态条（根据告警状态在代码中动态设置颜色） -->
        <View
            android:id="@+id/statusStripe"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="@color/colorPrimary"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- 行1：序号 + 工单号 + 告警状态 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <!-- 序号气泡 -->
                <TextView
                    android:id="@+id/tvIndex"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="1"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="@drawable/bg_badge_success"
                    android:includeFontPadding="false"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvBillSn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="工单号"
                    android:textColor="@color/colorPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"/>

                <TextView
                    android:id="@+id/tvAlertStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:text="告警中"
                    android:textColor="@color/warning_text"
                    android:textSize="11sp"
                    android:background="@drawable/bg_tag_warning"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- 行2：站点+工单标题 -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="站点名 - 工单标题"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingExtra="3dp"/>

            <!-- 行3：接单人 + 创建时间 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvAcceptOp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="接单人：-"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:drawableStart="@drawable/ic_person"
                    android:drawablePadding="6dp"/>

                <TextView
                    android:id="@+id/tvCreateTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="创建：-"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="12dp"/>

            <!-- 行4：最近处理 -->
            <TextView
                android:id="@+id/tvDealInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/success"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:drawableStart="@drawable/ic_check_circle"
                android:drawablePadding="6dp"/>

            <!-- 行5：工单历时 -->
            <TextView
                android:id="@+id/tvTimeDiff2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="工单历时：0分钟"
                android:textColor="@color/info"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"
                android:drawableStart="@drawable/ic_time"
                android:drawablePadding="6dp"/>

            <!-- 行6：上次反馈时间 -->
            <TextView
                android:id="@+id/tvTimeDiff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="上次反馈：尚未反馈"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>

            <!-- 行7：告警时间 -->
            <TextView
                android:id="@+id/tvAlertTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/warning"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"
                android:drawableStart="@drawable/ic_warning"
                android:drawablePadding="6dp"/>

            <!-- 行8：当前状态 -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--排队等待处理中..."
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
