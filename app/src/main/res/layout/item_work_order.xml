<?xml version="1.0" encoding="utf-8"?>
<!-- 优化版工单列表项 - 更简洁的布局结构，更丝滑的视觉体验 -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/background_secondary"
    app:rippleColor="@color/primary_light"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 顶部状态条 - 动态颜色 -->
        <View
            android:id="@+id/statusStripe"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:background="@color/colorPrimary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 内容区域 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            app:layout_constraintTop_toBottomOf="@+id/statusStripe"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 第一行：序号 + 工单号 + 告警状态 -->
            <TextView
                android:id="@+id/tvIndex"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="1"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:gravity="center"
                android:background="@drawable/bg_badge_success"
                android:includeFontPadding="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvBillSn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="工单号"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:ellipsize="end"
                android:maxLines="1"
                app:layout_constraintTop_toTopOf="@+id/tvIndex"
                app:layout_constraintBottom_toBottomOf="@+id/tvIndex"
                app:layout_constraintStart_toEndOf="@+id/tvIndex"
                app:layout_constraintEnd_toStartOf="@+id/tvAlertStatus"/>

            <TextView
                android:id="@+id/tvAlertStatus"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="告警中"
                android:textColor="@color/warning_text"
                android:textSize="11sp"
                android:background="@drawable/bg_tag_warning"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:gravity="center"
                android:includeFontPadding="false"
                app:layout_constraintTop_toTopOf="@+id/tvBillSn"
                app:layout_constraintBottom_toBottomOf="@+id/tvBillSn"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- 第二行：站点+工单标题 -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="站点名 - 工单标题"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingExtra="3dp"
                app:layout_constraintTop_toBottomOf="@+id/tvIndex"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- 第三行：接单人 + 创建时间 -->
            <TextView
                android:id="@+id/tvAcceptOp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="接单人：-"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:drawableStart="@drawable/ic_person"
                android:drawablePadding="6dp"
                android:ellipsize="end"
                android:maxLines="1"
                app:layout_constraintTop_toBottomOf="@+id/tvTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/tvCreateTime"/>

            <TextView
                android:id="@+id/tvCreateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="创建：-"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                app:layout_constraintTop_toTopOf="@+id/tvAcceptOp"
                app:layout_constraintBottom_toBottomOf="@+id/tvAcceptOp"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- 分割线 -->
            <View
                android:id="@+id/dividerContent"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@+id/tvAcceptOp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- 第四行：最近处理 -->
            <TextView
                android:id="@+id/tvDealInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text=""
                android:textColor="@color/success"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:drawableStart="@drawable/ic_check_circle"
                android:drawablePadding="6dp"
                app:layout_constraintTop_toBottomOf="@+id/dividerContent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- 第五行：工单历时 -->
            <TextView
                android:id="@+id/tvTimeDiff2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="工单历时：0分钟"
                android:textColor="@color/info"
                android:textSize="12sp"
                android:drawableStart="@drawable/ic_time"
                android:drawablePadding="6dp"
                app:layout_constraintTop_toBottomOf="@+id/tvDealInfo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- 第六行：上次反馈时间 -->
            <TextView
                android:id="@+id/tvTimeDiff"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="上次反馈：尚未反馈"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@+id/tvTimeDiff2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- 第七行：告警时间 -->
            <TextView
                android:id="@+id/tvAlertTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textColor="@color/warning"
                android:textSize="12sp"
                android:drawableStart="@drawable/ic_warning"
                android:drawablePadding="6dp"
                app:layout_constraintTop_toBottomOf="@+id/tvTimeDiff"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- 第八行：当前状态 -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="--排队等待处理中..."
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@+id/tvAlertTime"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
