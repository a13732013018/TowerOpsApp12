<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- TowerOps 主题 v5.0 — 顶级精工白金 -->
    <style name="Theme.TowerOpsApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#4F46E5</item>
        <item name="colorPrimaryDark">#4338CA</item>
        <item name="colorPrimaryVariant">#4338CA</item>
        <item name="colorAccent">#4F46E5</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#1E2347</item>
        <item name="android:windowBackground">#F4F6FB</item>
        <item name="android:statusBarColor">#4F46E5</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <!-- EditText 全局聚焦颜色 -->
        <item name="colorControlActivated">#4F46E5</item>
        <item name="colorControlHighlight">#1A4F46E5</item>
        <!-- 去除 Button 默认阴影波纹 -->
        <item name="materialButtonStyle">@style/PrimaryButton</item>
    </style>

    <!-- ===== Tab 主文字 · 13sp bold ===== -->
    <style name="TabTextStyle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- ===== 子Tab文字 · 12sp ===== -->
    <style name="TabTextSub" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- ===== 主按钮 · Indigo-600 ===== -->
    <style name="PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">#FFFFFF</item>
        <item name="backgroundTint">#4F46E5</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <!-- ===== 危险按钮 · Red-600 ===== -->
    <style name="DangerButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">#FFFFFF</item>
        <item name="backgroundTint">#DC2626</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <!-- ===== 成功按钮 · Emerald-600 ===== -->
    <style name="SuccessButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">#FFFFFF</item>
        <item name="backgroundTint">#059669</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <!-- ===== 次级按钮 ===== -->
    <style name="SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">#475569</item>
        <item name="strokeColor">#E2E8F0</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:minHeight">36dp</item>
    </style>

    <!-- ===== 幽灵按钮 ===== -->
    <style name="GhostButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">#475569</item>
        <item name="backgroundTint">#F1F5F9</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:minHeight">36dp</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- 卡片样式 v2.0 ═══════════════════════════════════════════════════ -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- 卡片悬浮态基类 -->
    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="rippleColor">@color/colorPrimaryLight</item>
    </style>

    <style name="CardStyle.Elevated" parent="CardStyle">
        <item name="cardElevation">6dp</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- 列表项样式 ═══════════════════════════════════════════════════ -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <style name="ListItemStyle">
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Tab样式 ═══════════════════════════════════════════════════════ -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <style name="TabStyle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">13sp</item>
    </style>

    <style name="TabStyle.Selected" parent="TabStyle">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/colorPrimary</item>
    </style>

    <style name="TabStyle.Unselected" parent="TabStyle">
        <item name="android:textColor">@color/tab_unselected</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- 排序标签样式 ═══════════════════════════════════════════════ -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <style name="SortTag" parent="">
        <item name="android:textSize">12sp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="SortTag.Active" parent="SortTag">
        <item name="android:textColor">@color/text_inverse</item>
        <item name="android:background">@drawable/bg_tag_primary</item>
    </style>

    <style name="SortTag.Inactive" parent="SortTag">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:background">@drawable/bg_tag_inactive</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- 输入框样式 ═══════════════════════════════════════════════════ -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <style name="InputStyle" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="InputStyle.Focused" parent="InputStyle">
        <item name="android:background">@drawable/bg_input_focused</item>
    </style>

    <style name="InputStyle.Normal" parent="InputStyle">
        <item name="android:background">@drawable/bg_input_white</item>
    </style>
</resources>
